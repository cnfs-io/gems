#!/bin/bash
# PCS managed — Proxmox VE installation for <%= hostname %>.<%= domain %>
set -euo pipefail

echo "=== Configuring hostname ==="
hostnamectl set-hostname <%= fqdn %>
cat > /etc/hosts <<'HOSTS'
<%= hosts_content %>HOSTS

echo "=== Adding Proxmox VE repository ==="
wget -qO /etc/apt/trusted.gpg.d/proxmox-release-<%= codename %>.gpg \
  http://download.proxmox.com/debian/proxmox-release-<%= codename %>.gpg 2>/dev/null || true

cat > /etc/apt/sources.list.d/pve-no-subscription.list <<'REPO'
deb http://download.proxmox.com/debian/pve <%= codename %> pve-no-subscription
REPO

rm -f /etc/apt/sources.list.d/pve-enterprise.list
rm -f /etc/apt/sources.list.d/ceph.list

echo "=== Pre-configuring postfix ==="
echo 'postfix postfix/mailname string <%= fqdn %>' | debconf-set-selections
echo 'postfix postfix/main_mailer_type string "Local only"' | debconf-set-selections

echo "=== Installing Proxmox VE packages ==="
apt-get update -y
DEBIAN_FRONTEND=noninteractive apt-get full-upgrade -y
DEBIAN_FRONTEND=noninteractive apt-get install -y proxmox-ve postfix open-iscsi chrony

echo "=== Removing old kernels ==="
apt-get remove -y linux-image-amd64 'linux-image-6.1*' 2>/dev/null || true
update-grub

echo "=== Enabling iSCSI services ==="
systemctl enable --now open-iscsi iscsid

echo "=== Proxmox VE installation complete ==="
echo "Reboot required."
