# PCS managed — Full DHCP + PXE boot
# Generated by pcs1 — do not edit manually

# Disable DNS (L1 handles it)
port=0

# Listen on control plane interface
interface=<%= interface %>
bind-dynamic

# Full DHCP — allocate IPs from pool
dhcp-range=<%= range_start %>,<%= range_end %>,<%= netmask %>,<%= lease_time %>
dhcp-option=option:router,<%= gateway %>
dhcp-option=option:dns-server,<%= dns_servers %>

# TFTP next-server (control plane)
dhcp-option=66,<%= ops_ip %>

# Logging
log-dhcp

# PXE boot files
dhcp-boot=netboot.xyz.efi,,<%= ops_ip %>
pxe-service=x86PC,"PCS netboot.xyz",netboot.xyz.kpxe,<%= ops_ip %>
pxe-service=x86-64_EFI,"PCS netboot.xyz",netboot.xyz.efi,<%= ops_ip %>
pxe-service=ARM64_EFI,"PCS netboot.xyz",netboot.xyz-arm64.efi,<%= ops_ip %>

# DHCP reservations (MAC -> configured IP -> hostname)
<%- reservations.each do |r| -%>
dhcp-host=<%= r[:mac] %>,<%= r[:ip] %>,<%= r[:hostname] %>
<%- end -%>
