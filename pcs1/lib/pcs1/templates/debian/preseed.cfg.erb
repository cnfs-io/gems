# Debian Preseed Configuration — generated by PCS for <%= hostname %>
d-i debian-installer/locale string en_US.UTF-8
d-i debian-installer/language string en
d-i debian-installer/country string US
d-i console-setup/ask_detect boolean false
d-i keyboard-configuration/xkb-keymap select us

# Network interface — auto picks the first with link
d-i netcfg/choose_interface select auto
d-i netcfg/get_hostname string <%= hostname %>
d-i netcfg/get_domain string <%= domain %>
d-i netcfg/get_hostname seen true
d-i netcfg/get_domain seen true

# Mirror configuration
d-i mirror/country string manual
d-i mirror/http/hostname string deb.debian.org
d-i mirror/http/directory string /debian
d-i mirror/http/proxy string

# Account setup
d-i passwd/root-login boolean false
d-i passwd/make-user boolean true
d-i passwd/user-fullname string <%= username %>
d-i passwd/username string <%= username %>
d-i passwd/user-password password <%= password %>
d-i passwd/user-password-again password <%= password %>

# Clock and time zone setup
d-i clock-setup/utc boolean true
d-i time/zone string <%= timezone %>
d-i clock-setup/ntp boolean true

# Remove any existing LVM configuration on the host
d-i partman/early_command string \
    for vg in $(vgs --noheadings -o vg_name 2>/dev/null); do \
        vgremove -f "$vg" 2>/dev/null || true; \
    done; \
    for pv in $(pvs --noheadings -o pv_name 2>/dev/null); do \
        pvremove -f "$pv" 2>/dev/null || true; \
    done; \
    wipefs -a <%= device %> 2>/dev/null || true; \
    dd if=/dev/zero of=<%= device %> bs=1M count=100 2>/dev/null || true

# Partitioning configuration
d-i partman-auto/method string lvm
d-i partman-auto/disk string <%= device %>
d-i partman-auto-lvm/guided_size string max
d-i partman-auto-lvm/new_vg_name string pve
d-i partman-lvm/device_remove_lvm boolean true
d-i partman-md/device_remove_md boolean true
d-i partman-lvm/confirm boolean true
d-i partman-lvm/confirm_nooverwrite boolean true

d-i partman-auto/expert_recipe string                         \
      proxmox-lvm ::                                          \
              538 538 1075 vfat                              \
                      $primary{ }                             \
                      $iflabel{ gpt }                         \
                      method{ efi } format{ }                 \
                      mountpoint{ /boot/efi }                 \
              .                                               \
              512 1024 1024 ext4                             \
                      $primary{ }                             \
                      method{ format } format{ }              \
                      use_filesystem{ }                       \
                      filesystem{ ext4 }                      \
                      mountpoint{ /boot }                     \
              .                                               \
              200000 200000 -1 ext4                          \
                      $primary{ }                             \
                      method{ lvm }                           \
                      vg_name{ pve }                          \
              .                                               \
              8192 8192 8192 linux-swap                      \
                      $lvmok{ }                               \
                      in_vg{ pve }                            \
                      lv_name{ swap }                         \
                      method{ swap } format{ }                \
              .                                               \
              90000 90000 90000 ext4                         \
                      $lvmok{ }                               \
                      in_vg{ pve }                            \
                      lv_name{ root }                         \
                      method{ format } format{ }              \
                      use_filesystem{ }                       \
                      filesystem{ ext4 }                      \
                      mountpoint{ / }                         \
              .                                               \
              100000 100000 -1 ext4                          \
                      $lvmok{ }                               \
                      in_vg{ pve }                            \
                      lv_name{ unused }                       \
                      method{ format } format{ }              \
                      use_filesystem{ }                       \
                      filesystem{ ext4 }                      \
                      mountpoint{ /unused }                   \
              .

d-i partman-partitioning/confirm_write_new_label boolean true
d-i partman/choose_partition select finish
d-i partman/confirm boolean true
d-i partman/confirm_nooverwrite boolean true

# GRUB installation
d-i grub-installer/only_debian boolean true
d-i grub-installer/bootdev string <%= device %>

# Base system installation
d-i base-installer/install-recommends boolean false
d-i base-installer/kernel/image string linux-image-amd64

# Package selection
tasksel tasksel/first multiselect standard, ssh-server
d-i pkgsel/include string <%= packages %>
d-i pkgsel/upgrade select safe-upgrade
popularity-contest popularity-contest/participate boolean false

# Late command — networking, hostname, sudoers, SSH keys, post-install script
d-i finish-install/reboot_in_progress note
d-i preseed/late_command string \
    echo '<%= hostname %>' > /target/etc/hostname; \
    printf '127.0.0.1 localhost\n<%= ip_address %> <%= hostname %>.<%= domain %> <%= hostname %>\n' > /target/etc/hosts; \
    printf 'auto lo\niface lo inet loopback\n\nauto <%= interface %>\niface <%= interface %> inet static\n    address <%= ip_address %>/<%= prefix_length %>\n    gateway <%= gateway %>\n    dns-nameservers <%= nameservers %>\n    dns-search <%= domain %>\n\nsource /etc/network/interfaces.d/*\n' > /target/etc/network/interfaces; \
    echo '<%= username %> ALL=(ALL) NOPASSWD:ALL' > /target/etc/sudoers.d/<%= username %>; \
    chmod 440 /target/etc/sudoers.d/<%= username %><% if authorized_keys_url %>; \
    mkdir -p /target/home/<%= username %>/.ssh; \
    wget -q -O /target/home/<%= username %>/.ssh/authorized_keys '<%= authorized_keys_url %>'; \
    chmod 700 /target/home/<%= username %>/.ssh; \
    chmod 600 /target/home/<%= username %>/.ssh/authorized_keys; \
    in-target chown -R <%= username %>:<%= username %> /home/<%= username %>/.ssh<% end %>; \
    wget -q -O /target/home/<%= username %>/post-install.sh '<%= base_url %>/<%= hostname %>.install.sh' || true; \
    chmod +x /target/home/<%= username %>/post-install.sh 2>/dev/null || true; \
    in-target chown <%= username %>:<%= username %> /home/<%= username %>/post-install.sh 2>/dev/null || true
